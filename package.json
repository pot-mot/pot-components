{
    "name": "@potmot/list",
    "private": false,
    "version": "0.0.1",
    "description": "An editable selectable list components lib.",
    "keywords": [
        "list",
        "selectable",
        "editable"
    ],
    "homepage": "https://github.com/pot-mot/list/blob/main/README.md",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pot-mot/list.git",
        "directory": "dist"
    },
    "bugs": {
        "url": "https://github.com/pot-mot/list/issues"
    },
    "type": "module",
    "license": "MIT",
    "author": "potmot",
    "main": "./dist/index.umd.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.umd.cjs"
        },
        "./*": "./*"
    },
    "files": [
        "package.json",
        "README.md",
        "LICENSE",
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "type-check": "vue-tsc --build --force",
        "build": "vue-tsc & vite build",
        "test": "vitest run",
        "lint:pritter": "prettier --write src/"
    },
    "lint-staged": {
        "*.{js,ts,vue,json,css}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@tsconfig/node22": "^22.0.5",
        "@types/jsdom": "^28.0.0",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^25.2.3",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vitest/coverage-v8": "3.2.4",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.9.0",
        "husky": "^9.1.7",
        "jsdom": "^29.0.0",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "typescript": "~5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^3.2.4",
        "vue-tsc": "^3.2.6"
    },
    "dependencies": {
        "clipboard-polyfill": "^4.1.1",
        "json5": "^2.2.3",
        "lodash-es": "^4.17.23",
        "mitt": "^3.0.1",
        "vue": "^3.5.30"
    }
}
